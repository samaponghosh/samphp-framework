# Auto detect text files and perform LF normalization
* text=auto

# PHP files
*.php text eol=lf

# Web assets
*.css text eol=lf
*.js text eol=lf
*.html text eol=lf

# Config
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.md text eol=lf

# Shell scripts
*.sh text eol=lf

# ============================================
# Export Ignore — Files excluded from Composer
# distribution (composer create-project).
# These files are only for development.
# ============================================
/.editorconfig       export-ignore
/.gitattributes      export-ignore
/.gitignore          export-ignore
/.github/            export-ignore
/CHANGELOG.md        export-ignore
/CONTRIBUTING.md     export-ignore
/SECURITY.md         export-ignore
/tests/              export-ignore
/phpunit.xml         export-ignore
